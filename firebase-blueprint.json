{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "role": { "type": "string", "enum": ["admin", "client"], "description": "User's role in the system" }
      },
      "required": ["uid", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "Logistics order data with detailed tracking and billing information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "uid": { "type": "string", "description": "Owner of the order" },
        "date": { "type": "string", "format": "date-time" },
        "product": { "type": "string" },
        "cost": { "type": "number" },
        "price": { "type": "number" },
        "shippingCharged": { "type": "number" },
        "shippingReal": { "type": "number" },
        "adsCost": { "type": "number" },
        "platformFee": { "type": "number" },
        "status": { "type": "string" },
        "provider": { "type": "string" },
        "country": { "type": "string" },
        "trackingId": { "type": "string" },
        "cancellationReason": { "type": "string" },
        "fechaReporte": { "type": "string" },
        "hora": { "type": "string" },
        "nombreCliente": { "type": "string" },
        "telefono": { "type": "string" },
        "emailCliente": { "type": "string" },
        "tipoIdentificacion": { "type": "string" },
        "nroIdentificacion": { "type": "string" },
        "tipoEnvio": { "type": "string" },
        "departamentoDestino": { "type": "string" },
        "ciudadDestino": { "type": "string" },
        "direccion": { "type": "string" },
        "notas": { "type": "string" },
        "transportadora": { "type": "string" },
        "numeroFactura": { "type": "string" },
        "valorFacturado": { "type": "number" },
        "valorCompraProductos": { "type": "number" },
        "gananciaManual": { "type": "number" },
        "precioFlete": { "type": "number" },
        "costoDevolucionFlete": { "type": "number" },
        "comision": { "type": "number" },
        "totalPreciosProveedor": { "type": "number" },
        "novedad": { "type": "string" },
        "fueSolucionadaNovedad": { "type": "string" },
        "horaNovedad": { "type": "string" },
        "fechaNovedad": { "type": "string" },
        "solucion": { "type": "string" },
        "horaSolucion": { "type": "string" },
        "fechaSolucion": { "type": "string" },
        "observacion": { "type": "string" },
        "usuarioSolucionaNovedad": { "type": "string" },
        "horaUltimoMovimiento": { "type": "string" },
        "fechaUltimoMovimiento": { "type": "string" },
        "ultimoMovimiento": { "type": "string" },
        "conceptoUltimoMovimiento": { "type": "string" },
        "ubicacionUltimoMovimiento": { "type": "string" },
        "vendedor": { "type": "string" },
        "tipoTienda": { "type": "string" },
        "tienda": { "type": "string" },
        "idOrdenTienda": { "type": "string" },
        "numeroPedidoTienda": { "type": "string" },
        "tags": { "type": "string" },
        "fechaGeneracionGuia": { "type": "string" },
        "usuarioGeneracionGuia": { "type": "string" },
        "codigoPostal": { "type": "string" },
        "contadorIndemnizaciones": { "type": "number" },
        "conceptoUltimaIndemnizacion": { "type": "string" },
        "categorias": { "type": "string" },
        "razonSocialFacturacion": { "type": "string" },
        "emailFacturacion": { "type": "string" },
        "fePais": { "type": "string" },
        "feTipoPersona": { "type": "string" },
        "feTipoDocumento": { "type": "string" },
        "feDocumento": { "type": "string" },
        "feMunicipio": { "type": "string" },
        "feDireccion": { "type": "string" },
        "feNumeroTelefono": { "type": "string" },
        "feTipoRegimen": { "type": "string" },
        "feTipoResponsabilidad": { "type": "string" },
        "feImpuesto": { "type": "string" }
      },
      "required": ["id", "orderId", "uid", "date", "product", "cost", "price", "status"]
    },
    "AdExpense": {
      "title": "AdExpense",
      "description": "Advertising expense record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "accountName": { "type": "string" },
        "platform": { "type": "string" },
        "amount": { "type": "number" },
        "timestamp": { "type": "number" }
      },
      "required": ["uid", "productName", "date", "platform", "amount"]
    },
    "MarketResearch": {
      "title": "MarketResearch",
      "description": "Market research data for a product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "productName": { "type": "string" },
        "storeUrls": { "type": "array", "items": { "type": "string" }, "description": "Up to 20 store URLs" },
        "notes": { "type": "string" },
        "videoUrls": { "type": "array", "items": { "type": "string" }, "description": "Video URLs" },
        "timestamp": { "type": "number" }
      },
      "required": ["uid", "productName"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Global orders collection"
    },
    "/ad_expenses/{expenseId}": {
      "schema": "AdExpense",
      "description": "Advertising expenses collection"
    },
    "/market_research/{researchId}": {
      "schema": "MarketResearch",
      "description": "Market research collection"
    }
  }
}
