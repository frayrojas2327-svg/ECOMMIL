{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "role": { "type": "string", "enum": ["admin", "client"], "description": "User's role in the system" }
      },
      "required": ["uid", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "Logistics order data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string", "description": "Owner of the order" },
        "date": { "type": "string", "format": "date-time" },
        "product": { "type": "string" },
        "cost": { "type": "number" },
        "price": { "type": "number" },
        "shippingCharged": { "type": "number" },
        "shippingReal": { "type": "number" },
        "adsCost": { "type": "number" },
        "platformFee": { "type": "number" },
        "status": { "type": "string", "enum": ["Confirmado", "En tránsito", "Devuelto", "Cancelado", "Pendiente"] },
        "provider": { "type": "string" },
        "country": { "type": "string" },
        "cancellationReason": { "type": "string" }
      },
      "required": ["id", "uid", "date", "product", "cost", "price", "status"]
    },
    "AdExpense": {
      "title": "AdExpense",
      "description": "Advertising expense record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "accountName": { "type": "string" },
        "platform": { "type": "string" },
        "amount": { "type": "number" },
        "timestamp": { "type": "number" }
      },
      "required": ["uid", "productName", "date", "platform", "amount"]
    },
    "MarketResearch": {
      "title": "MarketResearch",
      "description": "Market research data for a product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "productName": { "type": "string" },
        "storeUrls": { "type": "array", "items": { "type": "string" }, "description": "Up to 20 store URLs" },
        "notes": { "type": "string" },
        "videoUrls": { "type": "array", "items": { "type": "string" }, "description": "Video URLs" },
        "timestamp": { "type": "number" }
      },
      "required": ["uid", "productName"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Global orders collection"
    },
    "/ad_expenses/{expenseId}": {
      "schema": "AdExpense",
      "description": "Advertising expenses collection"
    },
    "/market_research/{researchId}": {
      "schema": "MarketResearch",
      "description": "Market research collection"
    }
  }
}
