{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "An ecommerce order from various platforms like Dropi or Shopify",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID of the order owner" },
        "orderId": { "type": "string", "description": "The external order ID" },
        "date": { "type": "string", "format": "date-time", "description": "Date of the order" },
        "product": { "type": "string" },
        "cost": { "type": "number" },
        "price": { "type": "number" },
        "shippingCharged": { "type": "number" },
        "shippingReal": { "type": "number" },
        "adsCost": { "type": "number" },
        "platformFee": { "type": "number" },
        "status": { "type": "string", "enum": ["Entregado", "En tránsito", "Devuelto", "Cancelado", "Pendiente", "Guía Generada", "Recolectado", "Incidencia"] },
        "provider": { "type": "string" },
        "country": { "type": "string" },
        "trackingId": { "type": "string" },
        "cancellationReason": { "type": "string" },
        "nombreCliente": { "type": "string" },
        "telefono": { "type": "string" },
        "emailCliente": { "type": "string" },
        "ciudadDestino": { "type": "string" },
        "departamentoDestino": { "type": "string" },
        "direccion": { "type": "string" },
        "transportadora": { "type": "string" },
        "numeroFactura": { "type": "string" },
        "valorFacturado": { "type": "number" },
        "valorCompraProductos": { "type": "number" },
        "gananciaManual": { "type": "number" },
        "precioFlete": { "type": "number" },
        "costoDevolucionFlete": { "type": "number" },
        "comision": { "type": "number" },
        "totalPreciosProveedor": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "orderId", "date", "status"]
    },
    "SavedProduct": {
      "title": "Saved Product Calculation",
      "description": "A saved calculation for a product's profitability",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "url": { "type": "string" },
        "notes": { "type": "string" },
        "currency": { "type": "string" },
        "inputs": { "type": "object" },
        "results": { "type": "object" },
        "timestamp": { "type": "number" }
      },
      "required": ["uid", "name", "timestamp"]
    }
  },
  "firestore": {
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of orders associated with users"
    },
    "savedProducts/{productId}": {
      "schema": "SavedProduct",
      "description": "Collection of saved product calculations"
    }
  }
}
