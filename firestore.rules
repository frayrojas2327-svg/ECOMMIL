rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }

    // Helper for Orders
    function isValidOrder(data) {
      return data.uid == request.auth.uid &&
             data.orderId is string && data.orderId.size() <= 100 &&
             data.status in ['Entregado', 'En tránsito', 'Devuelto', 'Cancelado', 'Pendiente', 'Guía Generada', 'Recolectado', 'Incidencia'] &&
             (data.price == null || data.price is number) &&
             (data.cost == null || data.cost is number);
    }

    // 1. Orders Collection
    match /orders/{orderId} {
      allow get: if isOwner(existing().uid);
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      
      allow create: if isSignedIn() && 
                      isValidId(orderId) &&
                      isValidOrder(incoming()) &&
                      incoming().keys().hasAll(['uid', 'orderId', 'date', 'status']);
      
      allow update: if isOwner(existing().uid) &&
                       isValidOrder(incoming()) &&
                       incoming().uid == existing().uid &&
                       incoming().orderId == existing().orderId &&
                       (
                         // Action: Status Update
                         (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
                         // Action: Full Edit (typical in this app)
                         true
                       );
      
      allow delete: if isOwner(existing().uid);
    }

    // 2. Saved Products Collection
    match /savedProducts/{productId} {
      allow get: if isOwner(existing().uid);
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create, update: if isSignedIn() && 
                             isValidId(productId) &&
                             incoming().uid == request.auth.uid;
      allow delete: if isOwner(existing().uid);
    }

    // 3. Users Collection
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && 
                      incoming().role == 'client' && 
                      incoming().keys().hasAll(['uid', 'email', 'role']);
      allow update: if isOwner(userId) && 
                      incoming().role == existing().role && // Prevent self-elevation
                      incoming().email == existing().email;
    }
  }
}
