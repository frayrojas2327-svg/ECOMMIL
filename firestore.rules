rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Global Safety Net
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Admin check - Restricted to 'get' operations to avoid list cost/complexity
    function isAdmin() {
      return isSignedIn() && 
        (
          request.auth.token.get('email', '').lower() in ["milnerdelacruz03@gmail.com", "mill03@gmail.com", "milner@gmail.com"] ||
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        );
    }

    // ===============================================================
    // Validation Blueprints
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['uid', 'status']) &&
             data.uid == request.auth.uid;
    }

    function isValidAdExpense(data) {
      return data.keys().hasAll(['uid', 'productName', 'date', 'platform', 'amount']) &&
             data.uid == request.auth.uid &&
             data.productName is string && data.productName.size() < 500 &&
             data.amount is number;
    }

    function isValidMarketResearch(data) {
      return data.keys().hasAll(['uid', 'productName']) &&
             data.uid == request.auth.uid &&
             data.productName is string && data.productName.size() < 500;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      // Identity Poisoning Guard
      allow get: if isOwner(userId) || isAdmin();
      // No List for users to prevent scraping/PII leaks
      allow list: if isOwner(userId) || isAdmin(); 
      
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming());
    }

    match /orders/{orderId} {
      // Secure List Query: Enforces that list queries MUST include the uid filter (unless admin)
      allow list: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update: if isSignedIn() && (existing().uid == request.auth.uid || isAdmin()) && isValidOrder(incoming());
      allow delete: if isSignedIn() && (existing().uid == request.auth.uid || isAdmin());
    }

    match /ad_expenses/{expenseId} {
      allow list: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && isValidAdExpense(incoming());
      allow update: if isSignedIn() && (existing().uid == request.auth.uid || isAdmin()) && isValidAdExpense(incoming());
      allow delete: if isSignedIn() && (existing().uid == request.auth.uid || isAdmin());
    }

    match /market_research/{researchId} {
      allow list: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && isValidMarketResearch(incoming());
      allow update: if isSignedIn() && (existing().uid == request.auth.uid || isAdmin()) && isValidMarketResearch(incoming());
      allow delete: if isSignedIn() && (existing().uid == request.auth.uid || isAdmin());
    }
  }
}
